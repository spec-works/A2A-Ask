{
  "build": {
    "content": [
      {
        "files": ["**.md", "**.yml"],
        "exclude": ["obj/**", "_site/**", "**/bin/**", "**/obj/**"]
      }
    ],
    "resource": [
      {
        "files": ["images/**"]
      }
    ],
    "output": "_site",
    "template": ["default", "modern", "template"],
    "globalMetadata": {
      "_appTitle": "A2A-Ask Documentation",
      "_appName": "A2A-Ask",
      "_appFooter": "<a href='https://spec-works.github.io/'>SpecWorks Factory</a> | <a href='https://github.com/spec-works/A2A-Ask'>GitHub</a>",
      "_enableSearch": true,
      "_enableNewTab": true,
      "_gitContribute": {
        "repo": "https://github.com/spec-works/A2A-Ask",
        "branch": "master"
      },
      "_appLogoPath": "images/logo.svg",
      "_appFaviconPath": "images/logo.svg"
    }
  }
}
